{
    "name": "type-lang/reader",
    "type": "library",
    "description": "Library for reading TypeLang AST nodes from types exposed by PHP Reflection objects",
    "keywords": ["converter", "language", "php", "parser", "reflection"],
    "license": "MIT",
    "support": {
        "source": "https://github.com/php-type-language/reader",
        "issues": "https://github.com/php-type-language/reader/issues"
    },
    "require": {
        "php": "^8.4",
        "type-lang/types": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "TypeLang\\Reader\\": "src"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2.5",
        "phpunit/phpunit": "^13.2.4",
        "type-lang/printer": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "TypeLang\\Reader\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.x-dev",
            "dev-main": "2.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "platform-check": true,
        "bin-compat": "full",
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        }
    },
    "scripts-aliases": {
        "test:unit": ["test", "phpunit", "unit"]
    },
    "scripts": {
        "test:unit": "phpunit --testdox"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
